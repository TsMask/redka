            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {"GO111MODULE": "on"},
            "args": ["-s"]
        },
        {
            "name": "MySQL",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/main.go",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {"GO111MODULE": "on"},
            "args": ["-c", "./config.mysql.yaml"]
        },
        {
            "name": "PostgreSQL",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/main.go",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {"GO111MODULE": "on"},
            "args": ["-c", "./config.postgres.yaml"]
        },
        {
            "name": "SQLite",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/main.go",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "env": {"GO111MODULE": "on"},
            "args": ["-c", "./config.sqlite.yaml"]
        }
